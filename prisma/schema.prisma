generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

//retrack changes

datasource db {
  provider = "postgresql"
}

enum CafeStaffRole {
  OWNER
  SERVER
  BARISTA
}

enum ObjectTypeEnum {
  TABLE
  SEAT
  WALL
  ROOM
}

enum MenuItemType {
  FOOD
  DRINK
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  workingAt  CafeStaff[]
  ownedCafes Cafe[]
}

model Cafe {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  ownerId   String

  owner  User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  staff  CafeStaff[]
  floors CafeFloor[]
  menus  Menu[]
  menuItems MenuItem[]
  bills  Bill[]
}

model CafeStaff {
  id        String        @id @default(cuid())
  userId    String
  cafeId    String
  role      CafeStaffRole
  createdAt DateTime      @default(now())
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe Cafe @relation(fields: [cafeId], references: [id])
}

model CafeFloor {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  cafeId    String

  cafe   Cafe    @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  canvas Canvas?
}

model Canvas {
  id          String    @id @default(cuid())
  height      Float
  width       Float
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  cafeFloorId String    @unique

  cafeFloor CafeFloor    @relation(fields: [cafeFloorId], references: [id], onDelete: Cascade)
  objects   CafeObject[]
}

model CafeObject {
  id           String         @id @default(cuid())
  pos_x_first  Float
  pos_y_first  Float
  pos_x_second Float
  pos_y_second Float
  metadata     Json?
  objectType   ObjectTypeEnum
  canvasId     String

  canvas Canvas @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  table  Table?
}

model Table {
  id           String   @id @default(cuid())
  tableNumber  Int
  createdAt    DateTime @default(now())
  cafeObjectId String   @unique

  cafeObject CafeObject @relation(fields: [cafeObjectId], references: [id], onDelete: Cascade)
  bills      Bill[]
}

model Menu {
  id        String    @id @default(cuid())
  name      String
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  cafeId    String

  cafe    Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  entries MenuEntry[]
}

model MenuItem {
  id          String        @id @default(cuid())
  name        String
  description String
  price       Decimal
  createdAt   DateTime      @default(now())
  deletedAt   DateTime?
  type        MenuItemType?
  cafeId      String

  cafe    Cafe        @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  entries MenuEntry[]
}

model MenuEntry {
  menuId     String
  menuItemId String

  menu     Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@id([menuId, menuItemId])
}

model Bill {
  id        String    @id @default(cuid())
  amount    Decimal
  paid      Boolean   @default(false)
  createdAt DateTime  @default(now())
  deletedAt DateTime?
  tableId   String
  cafeId    String

  table Table @relation(fields: [tableId], references: [id])
  cafe  Cafe  @relation(fields: [cafeId], references: [id], onDelete: Cascade)
}
