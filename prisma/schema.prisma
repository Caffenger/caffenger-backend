generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @unique @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  deletedAt DateTime?
}
